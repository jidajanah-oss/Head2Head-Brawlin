# NFL data provider
VITE_NFL_PROVIDER=espn

# Supabase browser configuration
# Copy this file to .env.local and replace the placeholders.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REFERENCE.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Never place a Supabase service-role or secret key in a Vite environment file.
